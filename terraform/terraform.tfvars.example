# Copy to terraform.tfvars and fill in real values once an Azure
# subscription exists. Never commit the filled-in file - terraform/.gitignore
# blanket-ignores terraform.tfvars (with an explicit exception for this file).

subscription_id = "REPLACE_WITH_REAL_SUBSCRIPTION_ID"
tenant_id       = "REPLACE_WITH_REAL_TENANT_ID"

# Supplied by the deploy workflow after its first image push; any non-empty
# value works for `terraform validate`/`plan` before that.
container_image = "shaganplaatjies.azurecr.io/shaganplaatjies:latest"

wp_domain = "blog.shaganplaatjies.co.za"

# TODO: flip to true once DNS delegation access for domain_name exists again.
# enable_custom_domain = true
